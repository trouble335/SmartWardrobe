<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smartwardrobe.mapper.WearRecordMapper">

    <resultMap id="WearRecordResultMap" type="com.smartwardrobe.entity.WearRecord">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="item_id" property="itemId"/>
        <result column="outfit_id" property="outfitId"/>
        <result column="wear_date" property="wearDate"/>
        <result column="weather_temp" property="weatherTemp"/>
        <result column="weather_desc" property="weatherDesc"/>
        <result column="occasion" property="occasion"/>
        <result column="note" property="note"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="findListByUserId" resultMap="WearRecordResultMap">
        SELECT * FROM wear_record
        WHERE user_id = #{userId}
        <if test="itemId != null">
            AND item_id = #{itemId}
        </if>
        <if test="outfitId != null">
            AND outfit_id = #{outfitId}
        </if>
        ORDER BY wear_date DESC, created_at DESC
    </select>

</mapper>
